---
export interface Props {
  title: string;
  description: string;
  href: string;
  tags?: string[];
  date?: string;
}
const { title, description, href, tags = [], date } = Astro.props;
---

<a href={href} class="project-card group">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <h3 class="text-sm font-medium group-hover:underline underline-offset-4 decoration-1 transition-colors">
        {title}
      </h3>
      <p class="mt-1 text-xs text-[hsl(var(--muted-foreground))] line-clamp-2">
        {description}
      </p>
      {tags.length > 0 && (
        <div class="mt-2 flex flex-wrap gap-1">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
    {date && (
      <span class="text-xs text-[hsl(var(--muted-foreground))] font-mono shrink-0 mt-0.5">
        {date}
      </span>
    )}
  </div>
</a>
