---
const { url } = Astro;
const path = url?.pathname || "/";
---

<header class="fade-up fixed top-0 left-0 right-0 z-50 bg-[hsl(var(--background))]/80 backdrop-blur-sm">
  <nav class="max-w-3xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href="/" class="font-mono text-sm font-medium hover:opacity-70 transition-opacity">
      吴卓阳
    </a>
    <div class="flex items-center gap-4 text-sm text-[hsl(var(--muted-foreground))] font-mono">
      <a href="/#about" class="hover:text-[hsl(var(--foreground))] transition-colors">About</a>
      <a href="/#projects" class="hover:text-[hsl(var(--foreground))] transition-colors">Projects</a>
      <a href="/#posts" class="hover:text-[hsl(var(--foreground))] transition-colors">Posts</a>
      <button
        id="theme-toggle"
        class="p-1 rounded-md hover:bg-[hsl(var(--muted))] transition-colors"
        aria-label="Toggle theme"
      >
        <span class="block dark:hidden text-base">🌙</span>
        <span class="hidden dark:block text-base">☀️</span>
      </button>
    </div>
  </nav>
</header>

<script>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', 
      document.documentElement.classList.contains('dark') ? 'dark' : 'light'
    );
  });
</script>
