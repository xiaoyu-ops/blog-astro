---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).filter((post) => import.meta.env.DEV || !post.data.draft);
posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const writingCategories = [
  {
    id: "notes",
    label: "Notes",
    empty: "还没有随手写。",
    posts: posts.filter((post) => post.data.category === "notes"),
  },
  {
    id: "technical",
    label: "Technical",
    empty: "技术文章正在整理中。",
    posts: posts.filter((post) => post.data.category === "technical"),
  },
] as const;

const projects = (await getCollection("projects")).filter((project) => !project.data.draft);
projects.sort((a, b) => {
  const orderA = a.data.order ?? Number.MAX_SAFE_INTEGER;
  const orderB = b.data.order ?? Number.MAX_SAFE_INTEGER;

  if (orderA !== orderB) {
    return orderA - orderB;
  }

  return new Date(b.data.date ?? 0).getTime() - new Date(a.data.date ?? 0).getTime();
});

const projectBeams = [
  ["#60a5fa", "#a78bfa"],
  ["#f97316", "#facc15"],
  ["#34d399", "#60a5fa"],
  ["#f472b6", "#c084fc"],
];
---

<Layout title="Zhuoyang Wu" description="吴卓阳 — 具身智能、AI Agent、数据系统。中山大学本科生。">
  <Header />

  <!-- Hero -->
  <section class="flex flex-col px-4 max-w-3xl mx-auto pt-24 md:pt-28 pb-8 overflow-x-clip">
    <div class="fade-up flex items-center justify-between gap-4 mb-4">
      <div class="flex items-center gap-3">
        <img
          src="/avatar-128.jpg"
          alt="Zhuoyang Wu"
          class="w-14 h-14 rounded-full object-cover ring-1 ring-[hsl(var(--border))]"
          width="56"
          height="56"
        />
        <div>
          <h1 class="text-lg font-medium tracking-tight">吴卓阳</h1>
          <p class="text-xs text-[hsl(var(--muted-foreground))] font-mono mt-0.5">
            Zhuoyang Wu
          </p>
        </div>
      </div>
      <div class="hero-sticker" data-hero-sticker>
        <span class="hero-sticker-quote" aria-hidden="true">
          做一点<br />有意义的工作
        </span>
        <img
          class="hero-sticker-fallback"
          src="/images/automail-sticker.png"
          alt="机械义肢主题的 Q 版人物贴纸"
          width="768"
          height="768"
          decoding="async"
        />
        <div class="hero-sticker-stage" data-hero-sticker-stage aria-hidden="true"></div>
        <span class="hero-sticker-hint" aria-hidden="true">拖动边缘</span>
      </div>
    </div>
    <p class="fade-up fade-delay-1 text-[hsl(var(--muted-foreground))] leading-relaxed text-sm mt-3">
      中山大学网络空间安全学院大三本科生。专注<strong class="text-[hsl(var(--foreground))] font-medium">Ai Agent</strong>，并探索<strong class="text-[hsl(var(--foreground))] font-medium">具身智能</strong>（VLA 模型与世界模型），
      探索机器人如何感知物理世界并自主决策，目前还是玩机械臂阶段。
    </p>
    <div class="fade-up fade-delay-2 mt-4 flex flex-wrap gap-1.5">
      <span class="inline-flex items-center rounded-md border border-[hsl(var(--border))] px-2 py-0.5 text-xs font-mono text-[hsl(var(--muted-foreground))] hover:text-[hsl(var(--foreground))] hover:border-[hsl(var(--foreground))/30] transition-colors">Go</span>
      <span class="inline-flex items-center rounded-md border border-[hsl(var(--border))] px-2 py-0.5 text-xs font-mono text-[hsl(var(--muted-foreground))] hover:text-[hsl(var(--foreground))] hover:border-[hsl(var(--foreground))/30] transition-colors">Python</span>
      <span class="inline-flex items-center rounded-md border border-[hsl(var(--border))] px-2 py-0.5 text-xs font-mono text-[hsl(var(--muted-foreground))] hover:text-[hsl(var(--foreground))] hover:border-[hsl(var(--foreground))/30] transition-colors">C++</span>
      <span class="inline-flex items-center rounded-md border border-[hsl(var(--border))] px-2 py-0.5 text-xs font-mono text-[hsl(var(--muted-foreground))] hover:text-[hsl(var(--foreground))] hover:border-[hsl(var(--foreground))/30] transition-colors">PyTorch</span>
      <span class="inline-flex items-center rounded-md border border-[hsl(var(--border))] px-2 py-0.5 text-xs font-mono text-[hsl(var(--muted-foreground))] hover:text-[hsl(var(--foreground))] hover:border-[hsl(var(--foreground))/30] transition-colors">ROS</span>
      <span class="inline-flex items-center rounded-md border border-[hsl(var(--border))] px-2 py-0.5 text-xs font-mono text-[hsl(var(--muted-foreground))] hover:text-[hsl(var(--foreground))] hover:border-[hsl(var(--foreground))/30] transition-colors">LangGraph</span>
      <span class="inline-flex items-center rounded-md border border-[hsl(var(--border))] px-2 py-0.5 text-xs font-mono text-[hsl(var(--muted-foreground))] hover:text-[hsl(var(--foreground))] hover:border-[hsl(var(--foreground))/30] transition-colors">PostgreSQL</span>
      <span class="inline-flex items-center rounded-md border border-[hsl(var(--border))] px-2 py-0.5 text-xs font-mono text-[hsl(var(--muted-foreground))] hover:text-[hsl(var(--foreground))] hover:border-[hsl(var(--foreground))/30] transition-colors">Redis</span>
      <span class="inline-flex items-center rounded-md border border-[hsl(var(--border))] px-2 py-0.5 text-xs font-mono text-[hsl(var(--muted-foreground))] hover:text-[hsl(var(--foreground))] hover:border-[hsl(var(--foreground))/30] transition-colors">Docker</span>
    </div>
    <div class="fade-up fade-delay-3 mt-4 flex flex-wrap items-center gap-x-5 gap-y-2 text-xs font-mono text-[hsl(var(--muted-foreground))]">
      <a href="https://github.com/xiaoyu-ops" class="inline-flex items-center gap-1.5 hover:text-[hsl(var(--foreground))] transition-colors" target="_blank" rel="noopener noreferrer">
        <svg class="h-3.5 w-3.5 shrink-0" data-contact-icon="github" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3.28-.36 6.72-1.61 6.72-7.25A5.65 5.65 0 0 0 19.22 3.3 5.27 5.27 0 0 0 19.13.3S17.95-.07 15 1.78a13.38 13.38 0 0 0-7 0C5.05-.07 3.87.3 3.87.3a5.27 5.27 0 0 0-.09 3A5.65 5.65 0 0 0 2.28 7.3c0 5.6 3.44 6.85 6.72 7.25A4.8 4.8 0 0 0 8 18v4" />
          <path d="M8 19c-3 .92-3-1.92-4-2" />
        </svg>
        GitHub
      </a>
      <a href="mailto:wuzhuoyang252@gmail.com" class="inline-flex items-center gap-1.5 hover:text-[hsl(var(--foreground))] transition-colors">
        <svg class="h-3.5 w-3.5 shrink-0" data-contact-icon="email" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="20" height="16" x="2" y="4" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
        Email
      </a>
      <span class="inline-flex items-center gap-1.5">
        <svg class="h-3.5 w-3.5 shrink-0" data-contact-icon="wechat" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15a4 4 0 0 1-4 4H8l-4 3v-3.5A7 7 0 1 1 8 5h7a6 6 0 0 1 6 10Z" />
          <path d="M8 12h.01M12 12h.01M16 12h.01" />
        </svg>
        微信: woshiwudachong
      </span>
    </div>
    <div class="fade-up fade-delay-4 mt-8 text-center">
      <span class="text-xs text-[hsl(var(--muted-foreground))/40] font-mono animate-pulse">↓ scroll</span>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="py-6 md:py-8 px-4 max-w-3xl mx-auto">
    <div class="fade-up group mb-4">
      <div class="flex items-center gap-2">
        <div class="decorate-bar h-4"></div>
        <h2 class="text-xs font-mono font-medium text-[hsl(var(--muted-foreground))] transition-colors duration-700 group-hover:text-[hsl(var(--foreground))]">About</h2>
      </div>
    </div>
    <div class="fade-up fade-delay-1 space-y-4 text-sm leading-relaxed text-[hsl(var(--muted-foreground))]">
      <p>
        中山大学<strong class="text-[hsl(var(--foreground))] font-medium">网络空间安全学院</strong>大三本科生（2027 届），
        就读于深圳校区，GPA 3.66/5.0。拥有约一年半的科研经验，主要方向为大模型训练数据去重和 AI 基础设施。就在7月1号，我考完了大学期间最后一门考试，结束快乐！我的论文投到ICDE还在审稿，希望一切顺利，审稿人求放过。
      </p>
      <p>
        此前在<strong class="text-[hsl(var(--foreground))] font-medium">深信服科技</strong>实习，负责自进化项目的数据挖掘算法开发。这是一个艰巨的项目！
        目前在探索<strong class="text-[hsl(var(--foreground))] font-medium">具身智能</strong>——VLA 模型与世界模型。
        最新在做我的论文阅读项目，我认为源源不断输入论文是很重要的，就算ai再强，我们也要丰富自己，做最后一环的决策，做一个适合大众并拥抱现在ai的阅读项目！
      </p>
      <p class="italic text-xs pt-4 border-t border-[hsl(var(--border))]">
        "做一点有意义的工作"
      </p>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="py-6 md:py-8 px-4 max-w-3xl mx-auto">
    <div class="fade-up group mb-3">
      <div class="flex items-center gap-2">
        <div class="decorate-bar h-4"></div>
        <h2 class="text-xs font-mono font-medium text-[hsl(var(--muted-foreground))] transition-colors duration-700 group-hover:text-[hsl(var(--foreground))]">Projects</h2>
      </div>
    </div>
    <div class="space-y-1">
      {projects.map((project, i) => {
        const [beamFrom, beamTo] = projectBeams[i % projectBeams.length];

        return (
          <a href={`/projects/${project.id}`} class={`fade-up fade-delay-${Math.min(i + 1, 4)} block -mx-4 px-4 py-2.5 rounded-lg border border-transparent hover:bg-[hsl(var(--muted))] hover:border-[hsl(var(--border))] hover:-translate-y-0.5 transition-all duration-300 group border-beam`} style={`--beam-from: ${beamFrom}; --beam-to: ${beamTo};`}>
            <div class="flex items-start justify-between gap-4 relative z-[1]">
              <div class="min-w-0">
                <h3 class="text-sm font-medium group-hover:underline underline-offset-4">{project.data.title}</h3>
                <p class="mt-1 text-xs text-[hsl(var(--muted-foreground))] group-hover:text-[hsl(var(--foreground))] transition-colors duration-300">{project.data.description}</p>
                {project.data.tags && project.data.tags.length > 0 && (
                  <div class="mt-2 flex flex-wrap gap-1">
                    {project.data.tags.map((tag: string) => (
                      <span class="inline-flex items-center rounded-md border border-[hsl(var(--border))] px-2 py-0.5 text-xs font-mono text-[hsl(var(--muted-foreground))]">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Writing -->
  <section id="posts" class="py-6 md:py-8 px-4 max-w-3xl mx-auto">
    <div class="fade-up group mb-3 flex items-end justify-between gap-4">
      <div class="flex items-center gap-2">
        <div class="decorate-bar h-4"></div>
        <h2 class="text-xs font-mono font-medium text-[hsl(var(--muted-foreground))] transition-colors duration-700 group-hover:text-[hsl(var(--foreground))]">Writing</h2>
      </div>
      <div class="writing-tabs flex items-center gap-3 font-mono text-xs" role="tablist" aria-label="Writing categories">
        {writingCategories.map((category) => (
          <button
            id={`writing-tab-${category.id}`}
            class:list={["writing-tab", { "is-active": category.id === "notes" }]}
            type="button"
            role="tab"
            aria-selected={category.id === "notes" ? "true" : "false"}
            aria-controls={`writing-panel-${category.id}`}
            tabindex={category.id === "notes" ? "0" : "-1"}
            data-writing-tab={category.id}
          >
            {category.label}
            <span class="writing-tab-count">{category.posts.length}</span>
          </button>
        ))}
      </div>
    </div>
    <div class="writing-window-shell fade-up fade-delay-1 relative">
      {writingCategories.map((category) => (
        <div
          id={`writing-panel-${category.id}`}
          class="writing-window"
          role="tabpanel"
          aria-labelledby={`writing-tab-${category.id}`}
          aria-label={`${category.label} writing`}
          tabindex={category.id === "notes" ? "0" : "-1"}
          data-writing-panel={category.id}
          hidden={category.id !== "notes"}
        >
          {category.posts.length > 0 ? (
            category.posts.map((post) => (
              <a href={`/blog/${post.id}`} class="writing-entry block -mx-4 px-4 py-2.5 rounded-lg border border-transparent hover:bg-[hsl(var(--muted))] hover:border-[hsl(var(--border))] transition-colors duration-200 group">
                <div class="flex h-full items-center justify-between gap-4">
                  <div class="min-w-0">
                    <h3 class="flex min-w-0 items-center gap-2 text-sm font-medium group-hover:underline underline-offset-4">
                      <span class="truncate">{post.data.title}</span>
                      {post.data.draft && (
                        <span class="rounded border border-[hsl(var(--border))] px-1.5 py-0.5 text-[0.625rem] font-mono font-normal text-[hsl(var(--muted-foreground))] no-underline">
                          Draft
                        </span>
                      )}
                    </h3>
                    <p class="writing-description mt-1 text-xs text-[hsl(var(--muted-foreground))] group-hover:text-[hsl(var(--foreground))] transition-colors duration-200">{post.data.description}</p>
                  </div>
                  <span class="text-xs text-[hsl(var(--muted-foreground))] font-mono shrink-0">{post.data.date}</span>
                </div>
              </a>
            ))
          ) : (
            <p class="writing-empty">{category.empty}</p>
          )}
        </div>
      ))}
      <div class="writing-scroll-cue" data-writing-scroll-cue hidden aria-hidden="true">
        ↓ Older writing
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="max-w-3xl mx-auto px-4 pb-8 text-xs text-[hsl(var(--muted-foreground))/50] font-mono">
    <div class="border-t border-[hsl(var(--border))] pt-4 flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
      <span>© 2026 Zhuoyang Wu</span>
      <span>
        Views <span id="view-total">—</span>
        <span class="opacity-40">·</span>
        Today <span id="view-today">—</span>
      </span>
    </div>
    <!-- Keep in sync with scripts/homepage-analytics.test.mjs. -->
    <div class="mt-4 flex justify-center">
      <script id="_waubmap">var _wau = _wau || []; _wau.push(["map", "blogxiaoyu66", "bmap", "250", "125", "night", "cross-pink"]);</script><script async src="https://waust.at/m.js"></script>
    </div>
  </footer>
</Layout>

<style>
  .writing-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    min-height: 2rem;
    padding-inline: 0.125rem;
    border-bottom: 1px solid transparent;
    color: hsl(var(--muted-foreground) / 0.58);
    transition: border-color 180ms ease, color 180ms ease;
  }

  .writing-tab:hover {
    color: hsl(var(--foreground));
  }

  .writing-tab.is-active {
    border-color: hsl(var(--foreground) / 0.72);
    color: hsl(var(--foreground));
  }

  .writing-tab:focus-visible,
  .writing-window:focus-visible {
    outline: 1px solid hsl(var(--foreground) / 0.55);
    outline-offset: 3px;
  }

  .writing-tab-count {
    color: hsl(var(--muted-foreground) / 0.46);
    font-size: 0.625rem;
  }

  .writing-window {
    height: 15rem;
    overflow-x: hidden;
    overflow-y: auto;
    overscroll-behavior-y: auto;
    scrollbar-color: hsl(var(--muted-foreground) / 0.24) transparent;
    scrollbar-gutter: stable;
    scrollbar-width: thin;
  }

  .writing-window::-webkit-scrollbar {
    width: 0.3rem;
  }

  .writing-window::-webkit-scrollbar-thumb {
    border-radius: 999px;
    background: hsl(var(--muted-foreground) / 0.24);
  }

  .writing-entry {
    height: 5rem;
  }

  .writing-description {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
  }

  .writing-empty {
    display: grid;
    height: 100%;
    place-items: center;
    color: hsl(var(--muted-foreground) / 0.54);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .writing-scroll-cue {
    position: absolute;
    right: 0.5rem;
    bottom: 0.25rem;
    z-index: 2;
    padding: 1.75rem 0.25rem 0.1rem 1.5rem;
    background: linear-gradient(to bottom, transparent, hsl(var(--background)) 58%);
    color: hsl(var(--muted-foreground) / 0.56);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    pointer-events: none;
  }

  .hero-sticker {
    position: relative;
    width: clamp(10rem, 27vw, 11.5rem);
    aspect-ratio: 1;
    flex: 0 0 auto;
    isolation: isolate;
  }

  .hero-sticker-quote {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 0;
    display: grid;
    place-items: center;
    width: 7rem;
    height: 7rem;
    color: hsl(var(--muted-foreground));
    font-family: var(--font-mono);
    font-size: 0.5rem;
    line-height: 1.55;
    text-align: center;
    text-wrap: nowrap;
    opacity: var(--hero-sticker-quote-opacity, 0);
    transform: translate(-50%, -50%);
    transition: opacity 120ms ease;
  }

  .hero-sticker-fallback {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 1;
    width: 7rem;
    height: 7rem;
    object-fit: contain;
    filter: drop-shadow(0 0.45rem 0.55rem hsl(var(--foreground) / 0.13));
    transform: translate(-50%, -50%) rotate(-3deg);
    transition: opacity 180ms ease;
  }

  .hero-sticker-stage {
    position: absolute;
    inset: 0;
    z-index: 2;
    width: 100%;
    height: 100%;
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease;
  }

  .hero-sticker-stage :global(sticker-forge) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero-sticker-hint {
    position: absolute;
    left: 50%;
    bottom: 0;
    z-index: 3;
    color: hsl(var(--muted-foreground) / 0.46);
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.04em;
    opacity: 0;
    transform: translate(-50%, 0.2rem);
    transition: opacity 180ms ease, transform 180ms ease;
    white-space: nowrap;
  }

  .hero-sticker.is-ready .hero-sticker-fallback {
    opacity: 0;
    pointer-events: none;
  }

  .hero-sticker.is-ready .hero-sticker-stage {
    opacity: 1;
    pointer-events: auto;
  }

  .hero-sticker.is-ready .hero-sticker-hint {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-sticker-fallback {
      transform: translate(-50%, -50%);
      transition: none;
    }

    .hero-sticker-hint {
      display: none;
    }
  }

  @media (min-width: 640px) {
    .hero-sticker-stage :global(sticker-forge) {
      transform: scale(1.18);
      transform-origin: center;
    }
  }
</style>

<script>
  interface StickerElement extends HTMLElement {
    setOptions(options: Record<string, unknown>): void;
    setSource(source: Record<string, unknown>): Promise<void>;
    setRenderScale(scale: number): void;
  }

  const heroSticker = document.querySelector<HTMLElement>("[data-hero-sticker]");
  const heroStickerStage = document.querySelector<HTMLElement>("[data-hero-sticker-stage]");

  if (heroSticker && heroStickerStage) {
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const navigatorWithConnection = navigator as Navigator & {
      connection?: { saveData?: boolean };
    };
    const canUseWebGL = "WebGLRenderingContext" in window;

    if (!reducedMotion && !navigatorWithConnection.connection?.saveData && canUseWebGL) {
      let loading = false;

      const loadSticker = async () => {
        if (loading || heroSticker.classList.contains("is-ready")) return;
        loading = true;

        try {
          await import("../vendor/sticker-forge.es.js");
          await customElements.whenDefined("sticker-forge");

          const sticker = document.createElement("sticker-forge") as StickerElement;
          sticker.style.cssText = "display:block;width:100%;height:100%";
          sticker.setOptions({
            outline: { width: 0, color: "#ffffff" },
            shadow: { opacity: 0.18, blur: 18, distance: 10, angle: 42 },
            peel: {
              radius: 0.15,
              stiffness: 0.78,
              maxAngle: 3.4,
              grabWidth: 28,
              release: "reset",
            },
            sound: { enabled: false, volume: 0 },
            back: { color: "#f5f3ef", gloss: 0.45, roughness: 0.55 },
            tilt: -3,
          });

          heroStickerStage.append(sticker);
          await sticker.setSource({
            type: "image",
            src: "/images/automail-sticker.png",
            name: "automail-sticker.png",
          });
          sticker.setRenderScale(1.25);

          const stickerCanvas = sticker.shadowRoot?.querySelector("canvas");
          if (stickerCanvas) {
            stickerCanvas.tabIndex = -1;
            stickerCanvas.style.outline = "none";
          }

          sticker.addEventListener("peelchange", (event) => {
            const progress = (event as CustomEvent<{ progress?: number }>).detail?.progress ?? 0;
            const quoteOpacity = Math.max(0, Math.min(1, (progress - 0.12) / 0.35));
            heroSticker.style.setProperty("--hero-sticker-quote-opacity", quoteOpacity.toString());
          });
          sticker.addEventListener("peelend", () => {
            window.setTimeout(() => {
              heroSticker.style.setProperty("--hero-sticker-quote-opacity", "0");
            }, 280);
          });

          heroSticker.classList.add("is-ready");
        } catch (error) {
          console.warn("Interactive sticker unavailable; keeping the static image.", error);
        }
      };

      const scheduleSticker = () => {
        if ("requestIdleCallback" in window) {
          window.requestIdleCallback(() => void loadSticker(), { timeout: 1800 });
        } else {
          window.setTimeout(() => void loadSticker(), 600);
        }
      };

      const observer = new IntersectionObserver(
        (entries) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            observer.disconnect();
            scheduleSticker();
          }
        },
        { rootMargin: "160px" },
      );

      observer.observe(heroSticker);
      heroSticker.addEventListener("pointerenter", () => void loadSticker(), { once: true });
      heroSticker.addEventListener("touchstart", () => void loadSticker(), { once: true, passive: true });
    }
  }
</script>

<script>
  const writingTabs = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-writing-tab]"));
  const writingPanels = Array.from(document.querySelectorAll<HTMLElement>("[data-writing-panel]"));
  const writingScrollCue = document.querySelector<HTMLElement>("[data-writing-scroll-cue]");

  const updateWritingScrollCue = (panel: HTMLElement) => {
    if (!writingScrollCue) return;

    const hasOlderWriting = panel.scrollHeight > panel.clientHeight + 1;
    const isAtBottom = panel.scrollTop + panel.clientHeight >= panel.scrollHeight - 2;
    writingScrollCue.hidden = !hasOlderWriting || isAtBottom;
  };

  const activateWritingCategory = (category: string, focusTab = false) => {
    const activeTab = writingTabs.find((tab) => tab.dataset.writingTab === category);
    const activePanel = writingPanels.find((panel) => panel.dataset.writingPanel === category);

    if (!activeTab || !activePanel) return;

    writingTabs.forEach((tab) => {
      const isActive = tab === activeTab;
      tab.classList.toggle("is-active", isActive);
      tab.setAttribute("aria-selected", isActive ? "true" : "false");
      tab.tabIndex = isActive ? 0 : -1;
    });

    writingPanels.forEach((panel) => {
      const isActive = panel === activePanel;
      panel.hidden = !isActive;
      panel.tabIndex = isActive ? 0 : -1;
    });

    activePanel.scrollTop = 0;
    updateWritingScrollCue(activePanel);
    if (focusTab) activeTab.focus();
  };

  writingTabs.forEach((tab, index) => {
    tab.addEventListener("click", () => {
      if (tab.dataset.writingTab) activateWritingCategory(tab.dataset.writingTab);
    });

    tab.addEventListener("keydown", (event) => {
      let nextIndex = index;

      if (event.key === "ArrowRight") nextIndex = (index + 1) % writingTabs.length;
      else if (event.key === "ArrowLeft") nextIndex = (index - 1 + writingTabs.length) % writingTabs.length;
      else if (event.key === "Home") nextIndex = 0;
      else if (event.key === "End") nextIndex = writingTabs.length - 1;
      else return;

      event.preventDefault();
      const nextCategory = writingTabs[nextIndex]?.dataset.writingTab;
      if (nextCategory) activateWritingCategory(nextCategory, true);
    });
  });

  writingPanels.forEach((panel) => {
    panel.addEventListener("scroll", () => updateWritingScrollCue(panel), { passive: true });
  });

  const initialWritingPanel = writingPanels.find((panel) => !panel.hidden);
  if (initialWritingPanel) updateWritingScrollCue(initialWritingPanel);

  window.addEventListener("resize", () => {
    const activePanel = writingPanels.find((panel) => !panel.hidden);
    if (activePanel) updateWritingScrollCue(activePanel);
  });
</script>
